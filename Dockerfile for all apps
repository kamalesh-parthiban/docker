Python
---------------

FROM python:3.12-slim

WORKDIR /app

COPY requirements.txt .
RUN pip install -r requirements.txt

COPY . .

EXPOSE 5000          # ← should be added, matching whatever port Flask/FastAPI web server listens on

CMD ["python", "app.py"]
------------------------------

installs Python libraries such as:

flask
requests
pandas
boto3

from requirements.txt.
---
COPY . .  copies:
  ✅ app.py
  ✅ requirements.txt (again)
  ✅ config.yaml
  ✅ everything in local folder
