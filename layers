FROM eclipse-temurin:17-jre-alpine    # Layer 1 — base JRE alpine image
WORKDIR /app                          # Layer 2 — creates /app directory
RUN addgroup -S appgroup && \
    adduser -S appuser -G appgroup    # Layer 3 — creates user and group
COPY --from=builder /app/target/*.jar # Layer 4 — copies JAR file
RUN chown appuser:appgroup app.jar    # Layer 5 — changes file ownership
USER appuser                          # Layer 6 — switches to non-root user
EXPOSE 8080                           # Layer 7 — exposes port (metadata only)
HEALTHCHECK ...                       # Layer 8 — health check (metadata only)
ENTRYPOINT ["java", "-jar", "app.jar"] # Layer 9 — run command (metadata only)

Only FROM, RUN, COPY, WORKDIR and USER create actual layers that consume disk space. EXPOSE, HEALTHCHECK and ENTRYPOINT are just metadata — 
they don't add any size to the image.
