Docker Compose simplifies running multi-container applications by allowing us to define services, networks, volumes, and build configurations in a single YAML file and manage everything together.

Some commonly used commands:
-> docker compose up -d – Start all services in detached mode
-> docker compose down – Stop and remove all services
-> docker compose ps – List containers created by Compose
-> docker compose images – View images used by Compose services
-> docker compose logs – View service logs

Docker Compose = Tool to define and run multi-container Docker applications using a single YAML file (docker-compose.yml).
Run all containers with one command: docker compose up — instead of running multiple docker run commands separately.

-----------------
version: '3.8'        ← docker compose version
services:             ← defines containers
  nginx:              ← container 1
  app:                ← container 2
  db:                 ← container 3
volumes:              ← persistent storage
-------------------

version: '3.8'

services:

  nginx:
    image: nginx:latest
    ports:
      - "80:80"
    volumes:
      - ./nginx.conf:/etc/nginx/nginx.conf
    depends_on:
      - app

  app:
    image: my-spring-boot-app:latest
    build: .
    ports:
      - "8080:8080"
    environment:
      - DB_HOST=db
      - DB_PORT=5432
      - DB_NAME=mydb
    depends_on:
      - db

  db:
    image: postgres:15
    environment:
      - POSTGRES_USER=admin
      - POSTGRES_PASSWORD=secret
      - POSTGRES_DB=mydb
    volumes:
      - pgdata:/var/lib/postgresql/data

volumes:
  pgdata:
